# ─────────────────────────────────────────────
# Berita Meureno — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google AdSense (optional) ─────────────────
# Replace with your actual client ID from adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ── App ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://berita.meureno.com

# ── Revalidation secret (for on-demand ISR) ──
REVALIDATION_SECRET=your-strong-random-secret-here
